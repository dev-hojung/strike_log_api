# 로컬 개발용 환경변수 샘플. 실제 값은 `.env`에 작성하고 커밋하지 말 것.
# 운영(Railway) 값은 Railway Variables 탭에서 별도로 관리한다.

# ─── 런타임 ──────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── MySQL ───────────────────────────────────────────────
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=
MYSQLDATABASE=strike_log

# 신규 빈 DB 부트스트랩 시 한 번만 true로. 운영에서는 항상 false.
TYPEORM_SYNCHRONIZE=false

# ─── 인증 ────────────────────────────────────────────────
JWT_SECRET=replace-with-strong-random-secret

# 운영 관리자 UUID (콤마 구분)
ADMIN_USER_IDS=

# ─── 이메일 (Resend) ─────────────────────────────────────
RESEND_API_KEY=

# ─── Firebase Admin (FCM) ────────────────────────────────
# 3개 필드를 모두 채우면 우선 사용. 비어있으면 FIREBASE_SERVICE_ACCOUNT_PATH 또는 GOOGLE_APPLICATION_CREDENTIALS 폴백.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# PEM의 줄바꿈은 \n 리터럴로 한 줄에 작성. (Railway Raw Editor도 동일하게 \n 사용)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
